{
    "dependencies": {
        "lodashEs": "npm:lodash@4.18.1",
        "vue": "3.5.32"
    },
    "devDependencies": {
        "@playwright/test": "1.59.1",
        "@types/node": "24.12.2",
        "@vitejs/plugin-vue": "6.0.5",
        "@vitest/ui": "^4.0.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-vue": "10.8.0",
        "prettier": "3.8.1",
        "vite": "8.0.7",
        "vitest": "4.1.3"
    },
    "name": "pivotable",
    "private": true,
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier .  --write",
        "lint": "eslint --fix src/main/resources/static",
        "lint_debug": "eslint --fix src/main/resources/static --debug",
        "preview": "vite preview",
        "unit_tests": "vitest",
        "unit_tests_ci": "vitest --reporter=html --outputFile=./vitest-report/test-output.html",
        "pw_localhost8080": "SPRING_ACTIVE_PROFILES=pivotable-unsafe npx playwright test localhost8080-queries --project=chromium",
        "pw_localhost8080_ui": "SPRING_ACTIVE_PROFILES=pivotable-unsafe npx playwright test localhost8080-queries --project=chromium --ui",
        "pw_localhost8080-webmvc": "SPRING_ACTIVE_PROFILES=pivotable-unsafe WEBMODE=webmvc npx playwright test localhost8080-queries --project=chromium",
        "pw_localhost8080-webmvc_ui": "SPRING_ACTIVE_PROFILES=pivotable-unsafe WEBMODE=webmvc npx playwright test localhost8080-queries --project=chromium --ui"
    },
    "type": "module",
    "version": "0.0.0"
}

{
    "dependencies": {
        "lodashEs": "npm:lodash@4.18.1",
        "vue": "3.5.32"
    },
    "devDependencies": {
        "@playwright/test": "1.59.1",
        "@types/node": "24.12.2",
        "@vitejs/plugin-vue": "6.0.6",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "monocart-coverage-reports": "^2.12.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-vue": "10.9.0",
        "prettier": "3.8.3",
        "vite": "8.0.10",
        "vitest": "4.1.5"
    },
    "name": "pivotable",
    "private": true,
    "scripts": {
        "build": "vite build",
        "dev_frontend": "vite",
        "dev_stack": "(trap 'kill 0' SIGINT; npm run backend & npm run dev_frontend; wait)",
        "format": "prettier .  --write",
        "lint": "eslint --fix src/main/resources/static",
        "lint_debug": "eslint --fix src/main/resources/static --debug",
        "preview": "vite preview",
        "unit_tests": "vitest",
        "unit_tests_ci": "vitest --reporter=html --outputFile=./vitest-report/test-output.html",
        "coverage_unit": "vitest run --coverage",
        "coverage_pw": "PW_COVERAGE=1 SPRING_ACTIVE_PROFILES=pivotable-unsafe npx playwright test --project=chromium",
        "coverage_merge": "node scripts/merge-coverage.mjs",
        "coverage_all": "npm run coverage_unit && npm run coverage_pw && npm run coverage_merge",
        "backend": "mvn -f ../server-${WEBMODE:-webflux}/pom.xml -Pfast spring-boot:run -Dspring-boot.run.profiles=${SPRING_ACTIVE_PROFILES:-pivotable-unsafe}",
        "backend_shorttoken": "SPRING_ACTIVE_PROFILES=pivotable-unsafe,pivotable-e2e-shorttoken npm run backend",
        "pw_localhost8080": "SPRING_ACTIVE_PROFILES=pivotable-unsafe npx playwright test localhost8080-queries --project=chromium",
        "pw_localhost8080_ui": "SPRING_ACTIVE_PROFILES=pivotable-unsafe npx playwright test localhost8080-queries --project=chromium --ui",
        "pw_localhost8080-webmvc": "SPRING_ACTIVE_PROFILES=pivotable-unsafe WEBMODE=webmvc npx playwright test localhost8080-queries --project=chromium",
        "pw_localhost8080-webmvc_ui": "SPRING_ACTIVE_PROFILES=pivotable-unsafe WEBMODE=webmvc npx playwright test localhost8080-queries --project=chromium --ui"
    },
    "type": "module",
    "version": "0.0.0"
}
